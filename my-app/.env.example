# ── Backend API URL ─────────────────────────────────────────────────────────
VITE_API_URL=https://localhost:7088/api

# ── Google OAuth Client ID ───────────────────────────────────────────────────
# Lấy tại: https://console.cloud.google.com/apis/credentials
# Bước: Tạo "OAuth 2.0 Client ID" loại "Web application"
# Thêm http://localhost:5173 vào "Authorized JavaScript origins"
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
